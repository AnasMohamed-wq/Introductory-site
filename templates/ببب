@layer utilities {
    /* تأثير تغير لون الناف بار عند السكرول */
    .nav-scrolled { 
        @apply bg-primary shadow-lg py-2; 
    }

    /* تأثير اللمعان (Shimmer) لزر الـ PDF */
    .shimmer-effect { 
        @apply relative overflow-hidden; 
    }
    .shimmer-effect::after {
        content: '';
        @apply absolute top-0 -left-[75%] w-1/2 h-full bg-gradient-to-r from-transparent via-white/30 to-transparent skew-x-[-25deg] pointer-events-none;
        animation: shimmer 3s infinite;
    }

    /* التحكم في حركة قائمة الموبايل الجانبية */
    #mobile-sidebar {
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        will-change: transform;
    }

    /* الكلاس الذي يظهر القائمة عند الضغط على الزر */
    .mobile-menu-open {
        transform: translateX(0) !important;
    }
}




<script>
    // 1. مراقبة التمرير لتغيير خلفية الـ Navbar
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (window.scrollY > 50) {
            nav.classList.add('nav-scrolled');
        } else {
            nav.classList.remove('nav-scrolled');
        }
    });

    // 2. التحكم في تبديل الوضع الليلي (Dark Mode) وتغيير الأيقونة
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    themeToggle.addEventListener('click', () => {
        if (html.classList.contains('dark')) {
            html.classList.remove('dark');
            themeToggle.innerHTML = '<span class="material-symbols-outlined">dark_mode</span>';
        } else {
            html.classList.add('dark');
            themeToggle.innerHTML = '<span class="material-symbols-outlined">light_mode</span>';
        }
    });

    // 3. التحكم في قائمة الموبايل (فتح/إغلاق وتغيير الأيقونة)
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileSidebar = document.getElementById('mobile-sidebar');
    const menuIcon = document.getElementById('menu-icon');

    if (mobileMenuBtn && mobileSidebar) {
        mobileMenuBtn.addEventListener('click', () => {
            // تبديل حالة القائمة
            mobileSidebar.classList.toggle('translate-x-full');
            mobileSidebar.classList.toggle('mobile-menu-open');
            
            // تغيير أيقونة القائمة ومنع التمرير عند الفتح
            if (mobileSidebar.classList.contains('mobile-menu-open')) {
                menuIcon.innerText = 'close';
                document.body.style.overflow = 'hidden'; 
            } else {
                menuIcon.innerText = 'menu';
                document.body.style.overflow = ''; 
            }
        });
    }

    // 4. إغلاق القائمة تلقائياً عند النقر على أي رابط بداخلها
    document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
            mobileSidebar.classList.add('translate-x-full');
            mobileSidebar.classList.remove('mobile-menu-open');
            menuIcon.innerText = 'menu';
            document.body.style.overflow = '';
        });
    });
</script>








